<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.hermes.code-index-watcher</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HERMES_INFRA_DIR</key>
        <string>/path/to/hermes-infra</string>
    </dict>

    <key>ProgramArguments</key>
    <array>
        <string>/path/to/hermes-infra/target/release/hermes-infra</string>
        <string>code-index-watch</string>
    </array>

    <!-- Replace $HOME with your actual home directory path -->
    <key>WorkingDirectory</key>
    <string>/path/to/hermes-infra/code-index</string>

    <key>StandardOutPath</key>
    <string>/path/to/hermes-infra/logs/code-index-watch.log</string>
    <key>StandardErrorPath</key>
    <string>/path/to/hermes-infra/logs/code-index-watch.log</string>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>
</dict>
</plist>
