# Hermes Infrastructure — Environment Variables
# Copy to .env and fill in your values.

# Port assignments
TEI_PORT=6999
CHROMA_PORT=8000

# Paths (use $HOME for portability)
HERMES_HOME=$HOME/.hermes
DEVELOPER_DIR=$HOME/Developer
SECOND_BRAIN_DIR=$HOME/Developer/second-brain

# API keys and tokens
OPENROUTER_API_KEY=your-key-here
DISCORD_TOKEN=your-token-here
