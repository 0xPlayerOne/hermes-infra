# Hermes Infrastructure — Environment Variables
# Copy to .env and fill in your values.

# Port assignments
TEI_PORT=6999
CHROMA_PORT=8000

# Paths (use $HOME for portability)
HERMES_HOME=$HOME/.hermes
HERMES_INFRA_DIR=/path/to/hermes-infra
HERMES_INFRA_VENV=$HERMES_INFRA_DIR/.venv
CODE_INDEX_VENV=$HERMES_INFRA_DIR/.venv
DEV_ROOT=$HOME/code
SECOND_BRAIN_DIR=$HOME/second-brain
DOCUMENTS_DIR=$HOME/Documents
WORK_SECTION=Work
PERSONAL_SECTION=Personal
SPECIAL_SECTION=Special

# Embeddings and local storage
TEI_PORT=6999
TEI_EMBED_URL=http://127.0.0.1:6999/v1/embeddings
EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B
CHROMA_DIR=$HOME/.hermes/code-index/chroma
HERMES_LOG_DIR=$HERMES_INFRA_DIR/logs
HERMES_LAUNCH_AGENTS_DIR=$HOME/Library/LaunchAgents

# API keys and tokens
OPENROUTER_API_KEY=your-key-here
DISCORD_TOKEN=your-token-here
