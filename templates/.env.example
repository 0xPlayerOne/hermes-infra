# Hermes Infrastructure — Environment Variables
# Copy to .env and fill in your values.

# Port assignments
CHROMA_PORT=8000

# Paths (use $HOME for portability)
HERMES_HOME=$HOME/.hermes
HERMES_INFRA_DIR=/path/to/hermes-infra
HERMES_INFRA_VENV=$HERMES_INFRA_DIR/.venv
HINDSIGHT_VENV=$HERMES_INFRA_DIR/.hindsight-venv
CODE_INDEX_VENV=$HERMES_INFRA_DIR/.venv
DEV_ROOT=$HOME/code
SECOND_BRAIN_DIR=$HOME/second-brain
DOCUMENTS_DIR=$HOME/Documents
WORK_SECTION=Work
PERSONAL_SECTION=Personal
SPECIAL_SECTION=Special
GOOGLE_WORK_ACCOUNT=work
GOOGLE_PERSONAL_ACCOUNT=personal
GOOGLE_SPECIAL_ACCOUNT=special
WORK_ROUTE_KEYWORDS=work,business
SPECIAL_ROUTE_KEYWORDS=special
WORK_GITHUB_OWNER=
STANDUP_CHANNEL=standup

# Embeddings and local storage
TEI_PORT=6999
TEI_EMBED_URL=http://127.0.0.1:6999/v1/embeddings
EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B
TEI_MEMORY_LIMIT_BYTES=2147483648
CHROMA_DIR=$HOME/.hermes/code-index/chroma
CODE_INDEX_STATE_FILE=$HOME/.hermes/code-index/manifest.json
HERMES_LOG_DIR=$HERMES_INFRA_DIR/logs
HERMES_LAUNCH_AGENTS_DIR=$HOME/Library/LaunchAgents
TEI_PLIST_NAME=com.hermes.tei.plist

# Optional daily intelligence sources
GITHUB_USER=
INTEL_REPOS=
ARXIV_CATEGORIES=cat:cs.AI+OR+cat:cs.CL+OR+cat:cs.CR+OR+cat:cs.SE

# Optional MTPLX context-sync paths
MTPLX_SETTINGS_PATH=$HOME/Library/Application Support/MTPLX/settings.json
MTPLX_CONTEXT_SYNC_LOCK=$HOME/Library/Application Support/MTPLX/.context-sync.lock
MTPLX_CONTEXT_PREFS_PATH=$HOME/.mtplx/context-windows-by-family.json

# Integration secrets belong in the owning service configuration,
# not in the infrastructure path and embedding environment.
