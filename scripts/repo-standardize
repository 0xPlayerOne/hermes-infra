#!/usr/bin/env python3
"""
repo-standardize — YEEZY OS stack enforcer.

Walks a repo, detects its primary language(s), and drops a correct AGENTS.md
so any agent (Hermes, Codex, opencode, Kilo) knows the toolchain WITHOUT guessing.

Constitution (locked):
  - TypeScript  -> Bun     (Next.js/React for web; npm only inside Unity Assets)
  - Python      -> uv      (pip is banned for agentic flows)
  - Rust        -> cargo   (aspirational default for CLI/systems/tools)
  - C# / Unity  -> NuGet   (locked, no choice)
  - Web stays TS. Do NOT rewrite web in Rust+WASM unless perf hotpath.

Usage:
  repo-standardize [path]            # detect + write AGENTS.md (dry-run prints if no path given is wrong; path required)
  repo-standardize --check [path]    # print what WOULD be written, don't write
  repo-standardize --force [path]    # overwrite existing AGENTS.md

Exit 0 = wrote/confirmed, 1 = bad args.
"""
import os
import sys
import json
import subprocess
from pathlib import Path

# ---- detection ----------------------------------------------------------
def detect(path: Path) -> dict:
    """Return detected stack signals."""
    sig = {
        "ts": 0, "py": 0, "rust": 0, "cs": 0, "sol": 0,
        "unity": False, "bun_lock": False, "npm_lock": False,
        "uv": False, "cargo": False, "sol_tool": None,
    }
    for root, dirs, files in os.walk(path):
        # skip noise
        dirs[:] = [d for d in dirs if d not in (
            "node_modules", ".git", "target", "__pycache__",
            "dist", "build", ".next", "out", "Library",
        )]
        for f in files:
            p = f.lower()
            if p.endswith(".sol"):
                sig["sol"] += 1
                # forge/hardhat config markers
                if p in ("foundry.toml", "hardhat.config.ts", "hardhat.config.js"):
                    sig["sol_tool"] = p
            if p == "package.json":
                sig["ts"] += 1
                # check if under Unity Assets
                if "Assets" in root.split(os.sep):
                    sig["unity"] = True
            elif p == "pyproject.toml" or p == "requirements.txt":
                sig["py"] += 1
            elif p == "cargo.toml":
                sig["rust"] += 1
                sig["cargo"] = True
            elif p.endswith(".cs"):
                sig["cs"] += 1
            elif p == "bun.lockb" or p == "bun.lock":
                sig["bun_lock"] = True
            elif p == "package-lock.json":
                sig["npm_lock"] = True
            elif p == "uv.lock":
                sig["uv"] = True
            elif p == "csproj" or p == "unitypackage":
                sig["cs"] += 1
    return sig

def primary_lang(sig: dict) -> str:
    if sig["rust"] > 0:
        return "rust"
    if sig["sol"] > 0:
        return "solidity"
    if sig["unity"] or (sig["cs"] > sig["ts"] and sig["cs"] > 0):
        return "unity-cs"
    if sig["ts"] > 0 and sig["py"] == 0:
        return "typescript"
    if sig["py"] > 0 and sig["ts"] == 0:
        return "python"
    if sig["ts"] > 0 and sig["py"] > 0:
        return "mixed-ts-py"
    if sig["cs"] > 0:
        return "unity-cs"
    return "unknown"

# ---- AGENTS.md templates ------------------------------------------------
def agents_md(lang: str, sig: dict, repo_name: str) -> str:
    header = f"""# AGENTS.md — {repo_name}

> Auto-generated by `repo-standardize` (YEEZY OS agentic constitution).
> Any AI agent working in this repo MUST follow the commands below. No guessing.

"""
    if lang == "solidity":
        tool = "Foundry (forge)" if sig["sol_tool"] == "foundry.toml" else "Hardhat"
        return header + f"""## Stack
- **Language:** Solidity (smart contracts)
- **Toolchain:** {tool}
- **Why:** Blockchain contracts. NOT a web app — do NOT treat package.json as a Bun web project.

## Commands
- Foundry:    `forge build` / `forge test` / `forge fmt`
- Hardhat:    `bun hardhat compile` / `bun hardhat test` (bun is the script runner, Solidity is the product)
- Deploy:     see `scripts/` or `deploy/` in repo

## Conventions
- `package.json` here drives Hardhat/Foundry, not a Next.js app. Agents: run contract commands, not `bun dev`.
- Never mix this with the web TS monorepo toolchain.
- Audit critical: `slither` or `forge inspect` before mainnet deploys.
"""
    if lang == "rust":
        return header + """## Stack
- **Language:** Rust
- **Package manager:** cargo (rustup-managed, stable-aarch64-apple-darwin)
- **Why:** Systems / CLI / perf-critical. This is the aspirational default for new tooling.

## Commands
- Build:      `cargo build`
- Release:    `cargo build --release`
- Test:       `cargo test`
- Lint:       `cargo clippy --all-targets -- -D warnings`
- Format:     `cargo fmt`
- Audit deps: `cargo audit`

## Conventions
- wasm32 target already installed (`rustup target add wasm32-unknown-unknown`) for browser interop.
- NO npm/cargo mix unless explicitly a wasm-bindgen project.
- If a Python CLI could be Rust, prefer Rust. Leave `// TODO(rust-migration)` breadcrumbs otherwise.
"""
    if lang == "typescript":
        pm = "bun" if (sig["bun_lock"] or not sig["npm_lock"]) else "bun (npm lock present — migrate to bun)"
        return header + f"""## Stack
- **Language:** TypeScript (web: Next.js / React)
- **Package manager:** {pm}
- **Why:** Web stays TypeScript. Tooling for Rust+WASM web is not ready; do NOT rewrite web in Rust.

## Commands
- Install:    `bun install`
- Dev:        `bun dev`
- Build:      `bun run build`
- Test:       `bun test`  (or `bun run test`)
- Lint:       `bun run lint`
- Typecheck:  `bun run typecheck` (or `tsc --noEmit`)

## Conventions
- Monorepo? Use workspace root scripts. Never `cd` into packages and run raw `npm`.
- Husky + lint-staged active. Commits run hooks — don't bypass with --no-verify.
- 5-verb repo standard: the repo exposes exactly 5 root scripts.
"""
    if lang == "python":
        pm = "uv" if sig["uv"] else "uv (NO pip — migrate lockfile to uv)"
        return header + f"""## Stack
- **Language:** Python 3.11+
- **Package manager:** {pm}
- **Why:** Glue, data, automation, ML. Mature for agentic flows.

## Commands
- Sync:       `uv sync`
- Run:        `uv run <module>`
- Test:       `uv run pytest`
- Lint:       `uv run ruff check .`
- Format:     `uv run ruff format .`

## Conventions
- `pyproject.toml` is the single source of truth. No setup.py sprawl.
- If this is a CLI/tool that could be Rust, mark with `# TODO(rust-migration)`.
- venvs live in `.venv`; never commit them.
"""
    if lang == "unity-cs":
        return header + """## Stack
- **Language:** C# (Unity)
- **Package manager:** NuGet / Unity Package Manager
- **Why:** Locked. Unity owns the runtime. No choice, no migration.

## Commands
- Build:      Unity Editor (CI uses Unity CLI / GameCI)
- Test:       Unity Test Runner (EditMode + PlayMode)

## Conventions
- `Assets/package.json` files are npm-in-Unity (jslib bridges) — separate from app TS.
- Do NOT run `bun install` at repo root expecting app behavior — those are Unity asset packages.
- Never let an agent treat the Unity project as a Node monorepo.
"""
    if lang == "mixed-ts-py":
        return header + """## Stack
- **Mixed:** TypeScript (web) + Python (glue/automation)
- **Package managers:** Bun (TS) + uv (Python) — NEVER mix pip into the TS side.

## Commands
- TS:   `bun install` / `bun run build` / `bun test`
- Py:   `uv sync` / `uv run pytest` / `uv run ruff check .`

## Conventions
- Keep the two stacks in separate top-level dirs (e.g. `web/` + `scripts/` or `py/`).
- Agents MUST detect which subtree they're in before running commands.
"""
    return header + """## Stack
- **Unknown / unmapped.**

## Action Required
Run `repo-standardize` after adding code, or manually declare the stack here.
"""

# ---- main ---------------------------------------------------------------
def main():
    args = sys.argv[1:]
    check_only = "--check" in args
    force = "--force" in args
    paths = [a for a in args if not a.startswith("--")]
    if not paths:
        print("usage: repo-standardize [--check|--force] <path>", file=sys.stderr)
        sys.exit(1)
    target = Path(paths[0]).resolve()
    if not target.is_dir():
        print(f"ERROR: {target} is not a directory", file=sys.stderr)
        sys.exit(1)

    sig = detect(target)
    lang = primary_lang(sig)
    repo_name = target.name
    content = agents_md(lang, sig, repo_name)
    out = target / "AGENTS.md"

    print(f"== repo-standardize: {target}")
    print(f"   detected: {lang}")
    print(f"   signals : ts={sig['ts']} py={sig['py']} rust={sig['rust']} cs={sig['cs']} sol={sig['sol']} "
          f"unity={sig['unity']} bun={sig['bun_lock']} npm={sig['npm_lock']} uv={sig['uv']}")

    if check_only:
        print("\n--- AGENTS.md (dry-run, not written) ---\n")
        print(content)
        return
    if out.exists() and not force:
        print(f"   SKIP: {out} exists (use --force to overwrite)")
        return
    out.write_text(content)
    print(f"   WROTE: {out}")

if __name__ == "__main__":
    main()
